{
  "name": "@followbrief/api",
  "version": "0.1.0",
  "private": true,
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:worker": "tsx watch src/worker.ts",
    "build": "prisma generate && tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "db:migrate": "DATABASE_URL=${DATABASE_URL:-postgresql://followbrief:followbrief@localhost:5432/followbrief} prisma db push",
    "db:generate": "DATABASE_URL=${DATABASE_URL:-postgresql://followbrief:followbrief@localhost:5432/followbrief} prisma generate",
    "db:seed": "DATABASE_URL=${DATABASE_URL:-postgresql://followbrief:followbrief@localhost:5432/followbrief} tsx prisma/seed.ts",
    "db:reset-demo": "RESET_DEMO_DATA=1 DATABASE_URL=${DATABASE_URL:-postgresql://followbrief:followbrief@localhost:5432/followbrief} tsx prisma/seed.ts"
  },
  "dependencies": {
    "@graphql-tools/schema": "^10.0.18",
    "@prisma/client": "^6.1.0",
    "bullmq": "^5.34.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "graphql": "^16.10.0",
    "graphql-scalars": "^1.24.0",
    "graphql-ws": "^6.0.3",
    "graphql-yoga": "^5.10.10",
    "ioredis": "^5.4.2",
    "pino": "^9.5.0",
    "ws": "^8.18.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/node": "^22.10.2",
    "@types/ws": "^8.5.13",
    "pino-pretty": "^13.0.0",
    "prisma": "^6.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
